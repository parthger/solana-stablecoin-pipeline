# Helius API (required)
HELIUS_API_KEY=your_helius_api_key_here

# AI Providers (optional - for AI insights, set at least one)
# Gemini is recommended (faster, free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (optional - defaults to local DuckDB)
DATABASE_URL=duckdb:///data/pipeline.duckdb
# DATABASE_URL=postgresql://user:pass@localhost:5432/stablecoins

# Optional: For real-time streaming (Phase 2)
# YELLOWSTONE_ENDPOINT=http://your-triton-node:10000
# YELLOWSTONE_TOKEN=your_token_here
